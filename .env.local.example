# ─── Supabase ─────────────────────────────────────────────────────────────────
# Trouve ces clés dans : https://supabase.com/dashboard → Project → Settings → API

# URL publique du projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé anon (publique, utilisée côté client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service_role (SECRÈTE — côté serveur uniquement, jamais exposée au client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Trouve ces clés dans : https://dashboard.stripe.com/apikeys
# Utilise les clés "test" en développement, "live" en production

# Clé publique (préfixe pk_test_ ou pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Clé secrète (préfixe sk_test_ ou sk_live_)
STRIPE_SECRET_KEY=sk_test_...

# Secret du webhook Stripe (préfixe whsec_)
# Crée un webhook sur https://dashboard.stripe.com/webhooks
# URL cible : https://ton-domaine.com/api/webhooks/stripe
# Événements à écouter : checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email — Brevo ────────────────────────────────────────────────────────────
# Crée un compte sur https://brevo.com → Paramètres → Clés API
BREVO_API_KEY=xkeysib-...

# ─── App ──────────────────────────────────────────────────────────────────────
# URL de base de l'application (sans slash final)
# En local : http://localhost:3000
# En production : https://ton-domaine.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Mot de passe pour accéder à l'interface admin (/admin)
ADMIN_PASSWORD=ton_mot_de_passe_admin
